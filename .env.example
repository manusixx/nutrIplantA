# ============================================================
# nutrI-plantA — variables de entorno
# ============================================================
# Copiar este archivo como .env y ajustar los valores marcados
# como CHANGEME antes de levantar el stack.
# ============================================================

# --- General ---
APP_ENV=development
LOG_LEVEL=INFO

# --- PostgreSQL ---
POSTGRES_USER=nutriplanta
POSTGRES_PASSWORD=CHANGEME_postgres_password
POSTGRES_DB=nutriplanta
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- MinIO (S3-compatible storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGEME_minio_password
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_DIAGNOSTICOS=diagnosticos

# --- Gateway ---
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080

# --- JWT (Sprint 2 en adelante) ---
JWT_SECRET_KEY=CHANGEME_genera_con_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Visión por computador (Sprint 5 en adelante) ---
VISION_PROVIDER=mock
CNN_VISION_URL=http://cnn-service:8000/predict
CNN_VISION_TIMEOUT=30
